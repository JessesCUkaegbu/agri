{
    "version": 2,
    "builds": [
      { "src": "agriProject/wsgi.py", "use": "@vercel/python" },
      { "src": "agriProject/static/**/*", "use": "@vercel/static" }
    ],
    "routes": [
      { "src": "/static/(.*)", "dest": "/agriProject/static/$1" },
      { "src": "/(.*)", "dest": "agriProject/wsgi.py" }
    ]
  }